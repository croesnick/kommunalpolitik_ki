{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "allgaeuer_zeitung_mcp": {
      "type": "local",
      "command": [
        "uv",
        "run",
        "--directory",
        "tools/allgaeuer_zeitung_mcp",
        "python",
        "-m",
        "newspaper_mcp"
      ],
      "environment": {
        "AZ_EMAIL": "${AZ_EMAIL}",
        "AZ_PASSWORD": "${AZ_PASSWORD}"
      }
    },
    "pdf_ingest": {
      "type": "local",
      "command": [
        "uv",
        "run",
        "--directory",
        "tools/pdf_ingest",
        "python",
        "-m",
        "pdf_ingest"
      ],
      "timeout": 300
    },
    "tidewave": {
      "type": "remote",
      "url": "http://localhost:4000/tidewave/mcp",
      "enabled": true
    },
    "ratsprojekte": {
      "type": "remote",
      "url": "http://localhost:4000/mcp",
      "enabled": true
    }
  },
  "skills": {
    "paths": ["skills"]
  }
}
