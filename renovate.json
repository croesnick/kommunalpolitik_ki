{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "lockFileMaintenance": { "enabled": false },
  "mix": {
    "managerFilePatterns": ["/(^|/)mix\\.exs$/"]
  },
  "packageRules": [
    {
      "description": "Bump mix.exs constraints; workspace.lock regenerated by mix deps.get in CI",
      "matchManagers": ["mix"],
      "rangeStrategy": "replace"
    },
    {
      "description": "Group Python dev deps per tool (like Dependabot dev groups did)",
      "matchManagers": ["pep621"],
      "matchDepTypes": ["dev"],
      "groupName": "dev deps"
    },
    {
      "description": "Group Python prod deps per tool",
      "matchManagers": ["pep621"],
      "matchDepTypes": ["dependencies"],
      "groupName": "prod deps"
    }
  ]
}
